{
  "manifest_version": 3,
  "name": "税务自动填报助手",
  "description": "在浏览器中本地运行税务报表自动填报工作流，无需联网。",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-128.png"
  },
  "background": {
    "service_worker": "background.bundle.js",
    "type": "module"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "commands": {
    "open-dashboard": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "打开本地工作流工作台"
    },
    "element-picker": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "打开元素选择器"
    }
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.bundle.js"],
      "run_at": "document_start",
      "match_about_blank": true,
      "all_frames": true
    }
  ],
  "optional_permissions": [
    "cookies",
    "downloads",
    "contextMenus",
    "clipboardRead",
    "notifications"
  ],
  "permissions": [
    "tabs",
    "proxy",
    "alarms",
    "storage",
    "debugger",
    "activeTab",
    "offscreen",
    "webNavigation",
    "unlimitedStorage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "/locales/*",
        "/icon-128.png",
        "/elementSelector.css",
        "elementSelector.bundle.js",
        "/Inter-roman-latin.var.woff2"
      ],
      "matches": [
        "*://*/*",
        "file://*/*"
      ]
    }
  ],
  "sandbox": {
    "pages": ["/sandbox.html"]
  }
}
